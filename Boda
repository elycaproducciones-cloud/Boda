<index.html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
<title>Juan Carlos & Elizabeth · Nuestro Amor Eterno</title>

<!-- Google Fonts + Font Awesome -->
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  --gold: #e4b363;
  --gold-light: #f3d382;
  --petrol: #0a2a2f;
  --petrol-soft: #123b42;
  --dark-bg: #030e11;
}

body {
  font-family: 'Montserrat', sans-serif;
  background: var(--dark-bg);
  color: #fef7e8;
  overflow-x: hidden;
  scroll-snap-type: y mandatory;
  scroll-behavior: smooth;
}

/* scroll snap sections */
.section {
  min-height: 100vh;
  scroll-snap-align: start;
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 2rem;
  background: #000000aa;
}

/* fondos con overlay más rico */
.bg {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center 30%;
  filter: brightness(0.45) contrast(1.05);
  z-index: 0;
  transition: transform 0.4s ease;
}

/* overlay sutil para legibilidad */
.section::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at center, transparent 40%, rgba(0,0,0,0.55) 100%);
  pointer-events: none;
  z-index: 1;
}

.content {
  position: relative;
  z-index: 10;
  max-width: 750px;
  width: 100%;
  background: rgba(3, 14, 17, 0.65);
  backdrop-filter: blur(3px);
  border-radius: 32px;
  padding: 2rem 2rem;
  border: 1px solid rgba(228, 179, 99, 0.3);
  box-shadow: 0 20px 35px -12px rgba(0,0,0,0.5);
  animation: fadeUp 1s ease forwards;
}

h1 {
  font-family: 'Cinzel', serif;
  font-size: 2.8rem;
  letter-spacing: 4px;
  font-weight: 600;
  text-shadow: 0 2px 10px rgba(0,0,0,0.5);
}

h1 span {
  color: var(--gold);
  font-weight: 700;
}

h2 {
  font-family: 'Cinzel', serif;
  font-size: 2.2rem;
  color: var(--gold);
  margin-bottom: 1rem;
  letter-spacing: 2px;
}

.quote {
  font-style: italic;
  font-size: 1.2rem;
  margin: 1rem 0;
  font-weight: 300;
  border-left: 3px solid var(--gold);
  padding-left: 1rem;
  display: inline-block;
}

p {
  font-size: 1.05rem;
  line-height: 1.65;
  font-weight: 400;
}

.date-large {
  margin-top: 1.2rem;
  font-size: 1.4rem;
  letter-spacing: 6px;
  color: var(--gold-light);
  font-family: 'Cinzel', serif;
}

.btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin-top: 28px;
  padding: 12px 32px;
  border-radius: 50px;
  background: var(--petrol);
  color: #fff;
  text-decoration: none;
  font-weight: 500;
  letter-spacing: 1px;
  transition: all 0.3s;
  border: 1px solid var(--gold);
  backdrop-filter: blur(4px);
}

.btn i {
  color: var(--gold);
}

.btn:hover {
  background: var(--gold);
  color: var(--petrol);
  border-color: var(--petrol);
  transform: scale(1.02);
}

.countdown {
  display: flex;
  gap: 20px;
  justify-content: center;
  margin: 35px 0 20px;
  flex-wrap: wrap;
}

.countdown div {
  background: rgba(10, 42, 47, 0.75);
  backdrop-filter: blur(5px);
  padding: 12px 18px;
  border-radius: 20px;
  min-width: 85px;
  border-bottom: 2px solid var(--gold);
}

.countdown span {
  display: block;
  font-size: 2rem;
  font-weight: 600;
  color: var(--gold);
  font-family: 'Cinzel', serif;
}

/* galería de fotos subidas por invitados */
.photo-upload-area {
  background: rgba(0, 0, 0, 0.5);
  border-radius: 28px;
  padding: 1.5rem;
  margin: 1.8rem 0;
  border: 1px dashed var(--gold);
}

.upload-btn-custom {
  background: var(--gold);
  border: none;
  padding: 10px 22px;
  border-radius: 40px;
  color: var(--petrol);
  font-weight: bold;
  cursor: pointer;
  transition: 0.2s;
  margin: 10px 0;
}

.upload-btn-custom:hover {
  background: #ffd966;
  transform: scale(0.98);
}

.gallery-preview {
  display: flex;
  flex-wrap: wrap;
  gap: 15px;
  justify-content: center;
  margin-top: 20px;
  max-height: 260px;
  overflow-y: auto;
  padding: 8px;
}

.gallery-preview img {
  width: 85px;
  height: 85px;
  object-fit: cover;
  border-radius: 18px;
  border: 2px solid var(--gold);
  transition: 0.2s;
  cursor: pointer;
}

.gallery-preview img:hover {
  transform: scale(1.05);
  filter: brightness(1.1);
}

.message-small {
  font-size: 0.8rem;
  margin-top: 8px;
  opacity: 0.8;
}

/* control de música */
.music-control {
  position: fixed;
  bottom: 25px;
  right: 25px;
  z-index: 999;
  background: var(--petrol);
  border-radius: 60px;
  padding: 12px 18px;
  cursor: pointer;
  box-shadow: 0 5px 15px rgba(0,0,0,0.4);
  border: 1px solid var(--gold);
  backdrop-filter: blur(5px);
  transition: 0.2s;
}

.music-control i {
  font-size: 1.7rem;
  color: var(--gold);
}

.music-control span {
  margin-left: 8px;
  font-size: 0.9rem;
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(40px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* responsive */
@media (max-width: 650px) {
  h1 { font-size: 1.9rem; }
  h2 { font-size: 1.6rem; }
  .countdown div { padding: 8px 10px; min-width: 65px; }
  .countdown span { font-size: 1.4rem; }
  .content { padding: 1.5rem; }
  .music-control { bottom: 18px; right: 18px; padding: 8px 14px; }
}
</style>
</head>
<body>

<!-- BOTÓN DE MÚSICA (instrumental romántica) -->
<div id="musicToggle" class="music-control">
  <i class="fas fa-music"></i> <span id="musicStatus">♫ Melodía</span>
</div>

<audio id="bgAudio" loop preload="auto">
  <source src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-2.mp3" type="audio/mpeg">
  <!-- fallback instrumental clásico de piano, pero usamos URL alternativa confiable (dominio gratuito) -->
</audio>

<!-- SECCIONES -->

<!-- PORTADA con frase emotiva -->
<section class="section">
  <div class="bg" style="background-image:url('https://images.pexels.com/photos/2253870/pexels-photo-2253870.jpeg?auto=compress&cs=tinysrgb&w=1600'); background-position: center 20%;"></div>
  <div class="content">
    <h1>Juan Carlos <span>&</span> Elizabeth</h1>
    <div class="quote">«Y aunque pasen los años, seguiré eligiéndote cada amanecer»</div>
    <p class="date-large">02 · MAYO · 2026</p>
    <div class="countdown">
      <div><span id="d">00</span>Días</div>
      <div><span id="h">00</span>Horas</div>
      <div><span id="m">00</span>Min</div>
      <div><span id="s">00</span>Seg</div>
    </div>
    <p style="margin-top: 20px; font-size:0.9rem;">“Donde hay amor, hay vida”</p>
  </div>
</section>

<!-- CEREMONIA con frase emotiva -->
<section class="section">
  <div class="bg" style="background-image:url('https://images.pexels.com/photos/2962393/pexels-photo-2962393.jpeg?auto=compress&cs=tinysrgb&w=1600'); background-position: center 35%;"></div>
  <div class="content">
    <h2><i class="fas fa-church"></i> Ceremonia Religiosa</h2>
    <p style="font-size:1.2rem;">“Hoy unimos nuestras almas ante Dios y el mundo”</p>
    <p><strong>Iglesia de La Magdalena</strong><br>5:00 PM · 2 de Mayo 2026</p>
    <a class="btn" target="_blank" href="https://maps.app.goo.gl/rSNB29egkLX4B2sz9">
      <i class="fas fa-map-marker-alt"></i> Ver ubicación
    </a>
  </div>
</section>

<!-- RECEPCIÓN con frase emotiva -->
<section class="section">
  <div class="bg" style="background-image:url('https://images.pexels.com/photos/2657560/pexels-photo-2657560.jpeg?auto=compress&cs=tinysrgb&w=1600'); background-position: center 40%;"></div>
  <div class="content">
    <h2><i class="fas fa-glass-cheers"></i> Recepción</h2>
    <p>“La fiesta comienza donde termina la ceremonia, brindemos por el amor eterno”</p>
    <p><strong>Jardín El Edén</strong><br>Al finalizar la ceremonia · Música, baile y sorpresas</p>
    <a class="btn" target="_blank" href="https://maps.app.goo.gl/QxB7McBEyXjfvJ4D8">
      <i class="fas fa-location-dot"></i> Cómo llegar
    </a>
  </div>
</section>

<!-- CONFIRMACIÓN ASISTENCIA + SECCIÓN SUBIR FOTOS (mejorada) -->
<section class="section">
  <div class="bg" style="background-image:url('https://images.pexels.com/photos/3171837/pexels-photo-3171837.jpeg?auto=compress&cs=tinysrgb&w=1600'); background-position: center 50%;"></div>
  <div class="content">
    <h2><i class="fas fa-heart"></i> Confirma tu asistencia</h2>
    <p>“Tu presencia hará aún más especial nuestro día”</p>
    <a class="btn" href="https://api.whatsapp.com/send?phone=5215516074050&text=Confirmo%20mi%20asistencia%20a%20su%20boda" target="_blank">
      <i class="fab fa-whatsapp"></i> Confirmar por WhatsApp
    </a>

    <!-- NUEVA SECCIÓN: COMPARTE FOTOS Y MENSAJES -->
    <div class="photo-upload-area">
      <i class="fas fa-camera-retro" style="color: var(--gold); font-size: 1.8rem;"></i>
      <p style="margin: 8px 0;"><strong>Álbum de recuerdos</strong><br>Sube una foto con tu mensaje de cariño</p>
      <input type="file" id="photoInput" accept="image/jpeg,image/png,image/jpg" style="display: none;">
      <button id="uploadPhotoBtn" class="upload-btn-custom"><i class="fas fa-upload"></i> Elegir foto</button>
      <div id="galleryContainer" class="gallery-preview">
        <!-- Aquí se mostrarán las fotos subidas temporalmente -->
        <p style="color:#ccc; width:100%; font-size:0.8rem;">Tus fotos aparecerán aquí 🌟</p>
      </div>
      <div class="message-small">
        <i class="fas fa-info-circle"></i> Las imágenes se guardan solo en esta sesión. Comparte tu mejor sonrisa.
      </div>
    </div>
  </div>
</section>

<script>
// ======================== COUNTDOWN ==========================
const eventDate = new Date("May 2, 2026 17:00:00").getTime();
const updateCountdown = () => {
  const now = new Date().getTime();
  const distance = eventDate - now;
  if (distance < 0) {
    document.getElementById("d").innerText = "0";
    document.getElementById("h").innerText = "0";
    document.getElementById("m").innerText = "0";
    document.getElementById("s").innerText = "0";
    return;
  }
  const days = Math.floor(distance / (1000 * 60 * 60 * 24));
  const hours = Math.floor((distance % (86400000)) / 3600000);
  const mins = Math.floor((distance % 3600000) / 60000);
  const secs = Math.floor((distance % 60000) / 1000);
  document.getElementById("d").innerText = days;
  document.getElementById("h").innerText = hours;
  document.getElementById("m").innerText = mins;
  document.getElementById("s").innerText = secs;
};
updateCountdown();
setInterval(updateCountdown, 1000);

// ======================== MÚSICA INSTRUMENTAL ==================
const audio = document.getElementById('bgAudio');
const musicToggle = document.getElementById('musicToggle');
const musicStatusSpan = document.getElementById('musicStatus');
let isPlaying = false;

// Intentar cargar audio instrumental (alternativa si no carga la primera)
audio.volume = 0.35;
// Fuente alternativa estable (instrumental romántico libre de derechos)
audio.src = "https://www.ashamaluevmusic.com/uploads/music/romantic-piano-instrumental.mp3";
audio.load();

// Autoplay? navegadores bloquean, por eso manejamos interacción usuario
const startMusic = () => {
  audio.play().then(() => {
    isPlaying = true;
    musicStatusSpan.innerText = "♫ Sonando";
    document.querySelector('#musicToggle i').className = "fas fa-volume-up";
  }).catch(e => {
    console.log("Autoplay bloqueado, espera clic");
    isPlaying = false;
    musicStatusSpan.innerText = "🎵 Silencio";
  });
};

musicToggle.addEventListener('click', () => {
  if (isPlaying) {
    audio.pause();
    isPlaying = false;
    musicStatusSpan.innerText = "🎵 Silencio";
    document.querySelector('#musicToggle i').className = "fas fa-music";
  } else {
    audio.play().then(() => {
      isPlaying = true;
      musicStatusSpan.innerText = "♫ Sonando";
      document.querySelector('#musicToggle i').className = "fas fa-volume-up";
    }).catch(err => {
      console.warn("Error al reproducir", err);
      alert("Haz clic nuevamente para activar la música instrumental ❤️");
    });
  }
});

// Pequeño helper para inicializar música con cualquier interacción en la página (primera vez)
let musicStarted = false;
function enableMusicOnFirstTouch() {
  if (!musicStarted) {
    startMusic();
    musicStarted = true;
    document.removeEventListener('click', enableMusicOnFirstTouch);
    document.removeEventListener('touchstart', enableMusicOnFirstTouch);
  }
}
document.addEventListener('click', enableMusicOnFirstTouch);
document.addEventListener('touchstart', enableMusicOnFirstTouch);

// ======================== SECCIÓN DE FOTOS (localStorage & galería dinámica) ==================
// Guardaremos las imágenes en base64 y también algún mensaje opcional (simple)
let photosArray = [];

// Cargar fotos guardadas en localStorage al iniciar
function loadPhotosFromStorage() {
  const stored = localStorage.getItem('wedding_photos_gallery');
  if (stored) {
    try {
      photosArray = JSON.parse(stored);
      renderGallery();
    } catch(e) { console.error(e); }
  } else {
    // datos demo opcionales (para mostrar ejemplo cariñoso)
    // no agregamos demo, pero si está vacío mostramos texto
    renderGallery();
  }
}

function savePhotosToStorage() {
  localStorage.setItem('wedding_photos_gallery', JSON.stringify(photosArray));
}

function renderGallery() {
  const galleryContainer = document.getElementById('galleryContainer');
  if (!galleryContainer) return;
  if (photosArray.length === 0) {
    galleryContainer.innerHTML = `<p style="color:#e4d5b0; width:100%; font-size:0.85rem;">✨ Comparte una foto con tu bendición para los novios ✨</p>`;
    return;
  }
  let html = '';
  photosArray.forEach((item, idx) => {
    // item = { dataUrl, caption (nombre o mensaje corto) }
    const captionText = item.caption || '💌 Con amor';
    html += `
      <div style="position:relative; display:inline-block;">
        <img src="${item.dataUrl}" alt="foto invitado" title="${captionText}" onclick="window.open('${item.dataUrl}','_blank')">
        <span style="position:absolute; bottom:-5px; left:0; right:0; background:#0a2a2fcc; font-size:9px; border-radius:10px; padding:2px 4px; color:gold;">${captionText.substring(0,18)}</span>
      </div>
    `;
  });
  galleryContainer.innerHTML = html;
}

// subir foto + pedir pequeño mensaje
document.getElementById('uploadPhotoBtn')?.addEventListener('click', () => {
  document.getElementById('photoInput').click();
});

document.getElementById('photoInput')?.addEventListener('change', function(event) {
  const file = event.target.files[0];
  if (!file) return;
  if (!file.type.startsWith('image/')) {
    alert("Por favor selecciona una imagen (jpg, png)");
    return;
  }
  const maxSize = 5 * 1024 * 1024;
  if (file.size > maxSize) {
    alert("La imagen es muy grande, máximo 5MB.");
    return;
  }
  const reader = new FileReader();
  reader.onload = function(e) {
    const imageDataUrl = e.target.result;
    // Pedir un breve mensaje o nombre
    let caption = prompt("Escribe tu nombre o un breve mensaje para los novios:", "Familia/Amigo");
    if (caption === null) caption = "Invitado especial";
    if (caption.trim() === "") caption = "❤️ Felicidades";
    photosArray.unshift({ dataUrl: imageDataUrl, caption: caption.slice(0, 30) });
    savePhotosToStorage();
    renderGallery();
    // Mostrar un pequeño toast emocional
    const toastMsg = document.createElement('div');
    toastMsg.innerText = "📸 ¡Foto agregada! Gracias por compartir tu cariño.";
    toastMsg.style.position = 'fixed';
    toastMsg.style.bottom = '90px';
    toastMsg.style.right = '20px';
    toastMsg.style.backgroundColor = '#0a2a2f';
    toastMsg.style.color = '#e4b363';
    toastMsg.style.padding = '8px 16px';
    toastMsg.style.borderRadius = '30px';
    toastMsg.style.zIndex = '999';
    toastMsg.style.fontSize = '0.8rem';
    toastMsg.style.border = '1px solid #e4b363';
    document.body.appendChild(toastMsg);
    setTimeout(() => toastMsg.remove(), 2800);
  };
  reader.readAsDataURL(file);
  event.target.value = ''; // reset input
});

// Cargar galería existente al cargar
loadPhotosFromStorage();

// Agregar frases emotivas flotantes extra: (mejora emocional)
const phrases = [
  "El amor todo lo espera, todo lo cree, todo lo soporta ❤️",
  "Hoy comienza la historia más hermosa",
  "Que su amor sea tan eterno como este día",
  "Bendiciones para Juan Carlos y Elizabeth ✨",
  "La dicha de compartir es el mayor regalo"
];
let phraseIndex = 0;
setInterval(() => {
  const quoteElements = document.querySelectorAll('.quote');
  if (quoteElements.length) {
    // solo cambia sutilmente en portada si deseas, no interrumpir demasiado
    const mainQuote = document.querySelector('.section:first-child .quote');
    if (mainQuote && Math.random() > 0.7) {
      mainQuote.style.transition = 'opacity 0.5s';
      mainQuote.style.opacity = '0.5';
      setTimeout(() => {
        mainQuote.innerText = `«${phrases[phraseIndex % phrases.length]}»`;
        mainQuote.style.opacity = '1';
        phraseIndex++;
      }, 150);
    }
  }
}, 6000);

// efecto suave al pasar secciones + mejorar scroll
const sections = document.querySelectorAll('.section');
const observerOptions = { threshold: 0.4 };
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.querySelector('.content')?.classList.add('animate__fadeIn');
    }
  });
}, observerOptions);
sections.forEach(s => observer.observe(s));

// Pequeño tooltip: añadir estilo adicional a la galería dinámica
const styleExtra = document.createElement('style');
styleExtra.textContent = `
  .gallery-preview::-webkit-scrollbar { width: 5px; }
  .gallery-preview::-webkit-scrollbar-track { background: #0f2a33; border-radius: 10px; }
  .gallery-preview::-webkit-scrollbar-thumb { background: #e4b363; border-radius: 10px; }
`;
document.head.appendChild(styleExtra);
</script>
</body>
</html>
